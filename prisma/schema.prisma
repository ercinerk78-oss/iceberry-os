  updatedAt     DateTime @updatedAt
  order         FranchiseOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  items         PickingListItem[]

  @@index([warehouseId, status])
  @@index([orderId])
}

model PickingListItem {
  id              String   @id @default(cuid())
  pickingListId   String
  orderItemId     String
  productId       String
  lotId           String?
  requestedQuantity Float
  pickedQuantity  Float    @default(0)
  missingQuantity Float    @default(0)
  status          String   @default("OPEN")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pickingList     PickingList @relation(fields: [pickingListId], references: [id], onDelete: Restrict)
