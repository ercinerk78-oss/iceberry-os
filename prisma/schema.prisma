  @@index([orderId, status])
  @@index([warehouseId, status])
}

model ReturnItem {
  id          String   @id @default(cuid())
  returnId    String
  orderItemId String
  productId   String
  quantity    Float
  acceptedQuantity Float @default(0)
  quarantinedQuantity Float @default(0)
  damagedQuantity Float @default(0)
