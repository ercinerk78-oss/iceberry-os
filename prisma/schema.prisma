  lot             InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@unique([shipmentId, orderItemId])
  @@index([shipmentId])
  @@index([orderItemId])
  @@index([lotId])
}

model DeliveryIssue {
  id          String   @id @default(cuid())
  orderId     String
