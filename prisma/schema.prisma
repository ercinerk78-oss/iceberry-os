generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FranchiseCandidate {
  id                String                 @id @default(cuid())
  fullName          String
  phone             String
  whatsapp          String?
  email             String?
  city              String
  district          String?
  country           String                 @default("Türkiye")
  investmentBudget  String
  currency          String                 @default("TRY")
  interestedConcept String
  source            String
  status            String                 @default("Yeni Lead")
  temperature       String                 @default("Ilık")
  generalNotes      String?
  nextFollowUpAt    DateTime?
  lastContactAt     DateTime?
  lostReason        String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  archivedAt        DateTime?
  assignedUserId    String?
  interactions      CandidateInteraction[]
  tasks             CandidateTask[]
  documents         Document[]
  franchisee        Franchisee?
  branch            Branch?

  @@index([archivedAt, createdAt])
  @@index([city])
  @@index([status])
}

model Document {
  id               String              @id @default(cuid())
  fileName         String              @unique
  originalFileName String
  filePath         String
  mimeType         String
  fileSize         Int
  documentType     String
  version          String
  description      String?
  candidateId      String?
  locationId       String?
  branchId         String?
  franchiseeId     String?
  openingId        String?
  uploadedBy       String?
  uploadedAt       DateTime            @default(now())
  customerShared   Boolean             @default(false)
  customerSharedAt DateTime?
  archivedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  candidate        FranchiseCandidate? @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  franchisee       Franchisee?         @relation(fields: [franchiseeId], references: [id], onDelete: Restrict)
  branch           Branch?             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  opening          BranchOpening?      @relation(fields: [openingId], references: [id], onDelete: Restrict)
  revenueRecords   BranchRevenueRecord[]

  @@index([candidateId, documentType, uploadedAt])
  @@index([locationId])
  @@index([branchId])
  @@index([franchiseeId])
  @@index([openingId])
  @@index([documentType, archivedAt])
}

model Franchisee {
  id                        String              @id @default(cuid())
  companyName               String
  contactName               String
  phone                     String
  whatsapp                  String?
  email                     String?
  taxNumber                 String?
  taxOffice                 String?
  city                      String
  district                  String?
  address                   String?
  candidateId               String?             @unique
  status                    String              @default("SETUP")
  contractDate              DateTime?
  contractStartDate         DateTime?
  contractEndDate           DateTime?
  defaultRoyaltyRate        Float?
  marketingContributionRate Float?
  generalNotes              String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  archivedAt                DateTime?
  candidate                 FranchiseCandidate? @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  branches                  Branch[]
  documents                 Document[]
  orders                    FranchiseOrder[]

  @@index([status, archivedAt])
  @@index([city])
}

model Branch {
  id                        String           @id @default(cuid())
  franchiseeId              String?
  candidateId               String?          @unique
  sourceLeadId              String?
  branchCode                String?          @unique
  branchName                String
  legalName                 String?
  tradeName                 String?
  ownershipType             String           @default("FRANCHISE")
  conceptType               String?
  city                      String
  district                  String?
  address                   String?
  country                   String           @default("Türkiye")
  latitude                  Float?
  longitude                 Float?
  phone                     String?
  email                     String?
  mallName                  String?
  floor                     String?
  unitNumber                String?
  squareMeters              Float?
  authorizedPersonName      String?
  authorizedPersonPhone     String?
  authorizedPersonEmail     String?
  taxOffice                 String?
  taxNumber                 String?
  billingAddress            String?
  concept                   String
  locationType              String
  openingDate               DateTime?
  plannedOpeningDate        DateTime?
  closingDate               DateTime?
  contractStartDate         DateTime?
  contractEndDate           DateTime?
  leaseStartDate            DateTime?
  leaseEndDate              DateTime?
  rentAmount                Float?
  turnoverRentRate          Float?
  depositAmount             Float?
  royaltyRate               Float?
  marketingContributionRate Float?
  managerName               String?
  managerPhone              String?
  managerEmail              String?
  operationsManager         String?
  status                    String           @default("PLANNED")
  generalNotes              String?
  createdById               String?
  lastAuditAt               DateTime?
  lastAuditScore            Float?
  healthScore               Float?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  archivedAt                DateTime?
  franchisee                Franchisee?      @relation(fields: [franchiseeId], references: [id], onDelete: Restrict)
  candidate                 FranchiseCandidate? @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  documents                 Document[]
  openings                  BranchOpening[]
  orders                    FranchiseOrder[]
  users                     BranchUser[]
  tasks                     BranchTask[]
  revenueRecords            BranchRevenueRecord[]
  audits                    BranchAudit[]
  developmentPlans          BranchDevelopmentPlan[]
  operationCalendarItems    OperationCalendarItem[]
  timeline                  BranchTimelineEvent[]
  externalMappings          ExternalBranchMapping[]
  deliveryIssues            DeliveryIssue[]
  supplyAlerts              SupplyComplianceAlert[]
  financialProfile          BranchFinancialProfile?
  ledgerAccounts            BranchLedgerAccount[]
  ledgerEntries             BranchLedgerEntry[]
  royaltyAccruals           RoyaltyAccrual[]
  collectionPayments        CollectionPayment[]
  financialReconciliations  BranchFinancialReconciliation[]
  financialDisputes         FinancialDispute[]
  financialActivities       FinancialActivityLog[]

  @@index([franchiseeId, archivedAt])
  @@index([candidateId])
  @@index([branchCode])
  @@index([ownershipType])
  @@index([conceptType])
  @@index([city])
  @@index([status, plannedOpeningDate])
}

model BranchUser {
  id        String   @id @default(cuid())
  branchId  String
  userId    String
  role      String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([branchId, userId])
  @@index([userId])
  @@index([branchId, role])
}

model BranchTask {
  id                  String         @id @default(cuid())
  title               String
  description         String?
  branchId            String
  assignedUserId      String?
  assignedRole        String?
  createdById         String?
  priority            String         @default("NORMAL")
  status              String         @default("OPEN")
  startDate           DateTime?
  dueDate             DateTime?
  submittedAt         DateTime?
  reviewedAt          DateTime?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  completedAt         DateTime?
  reviewerUserId      String?
  rejectionReason     String?
  completionNote      String?
  progress            Int            @default(0)
  requiresPhoto       Boolean        @default(false)
  requiresVideo       Boolean        @default(false)
  requiresFile        Boolean        @default(false)
  requiresDescription Boolean        @default(false)
  requiresResultNote  Boolean        @default(false)
  minimumPhotoCount   Int            @default(0)
  minimumVideoCount   Int            @default(0)
  minimumFileCount    Int            @default(0)
  requiresApproval    Boolean        @default(true)
  sourceType          String?
  sourceId            String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  branch              Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  assignedUser        User?          @relation("BranchTaskAssignedUser", fields: [assignedUserId], references: [id], onDelete: Restrict)
  createdBy           User?          @relation("BranchTaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  reviewer            User?          @relation("BranchTaskReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  evidence            TaskEvidence[]

  @@index([branchId, status])
  @@index([assignedUserId, status])
  @@index([dueDate, status])
  @@index([sourceType, sourceId])
}

model TaskEvidence {
  id           String     @id @default(cuid())
  taskId       String
  evidenceType String
  fileName     String?
  mimeType     String?
  fileSize     Int?
  storageKey   String?
  description  String?
  uploadedById String?
  uploadedAt   DateTime   @default(now())
  metadata     String?
  createdAt    DateTime   @default(now())
  task         BranchTask @relation(fields: [taskId], references: [id], onDelete: Restrict)
  uploadedBy   User?      @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([taskId, evidenceType])
  @@index([uploadedById, uploadedAt])
}

model BranchRevenueRecord {
  id                String    @id @default(cuid())
  branchId          String
  periodType        String    @default("MONTHLY")
  periodStart       DateTime
  periodEnd         DateTime
  year              Int
  month             Int
  grossRevenue      Float
  netRevenue        Float?
  targetRevenue     Float?
  transactionCount  Int?
  averageTicket     Float?
  currency          String    @default("TRY")
  source            String    @default("MANUAL")
  status            String    @default("DRAFT")
  notes             String?
  rejectionReason   String?
  supportDocumentId String?
  enteredById       String?
  approvedById      String?
  approvedAt        DateTime?
  lockedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  branch            Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supportDocument   Document? @relation(fields: [supportDocumentId], references: [id], onDelete: SetNull)
  enteredBy         User?     @relation("RevenueEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)
  approvedBy        User?     @relation("RevenueApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([branchId, periodType, periodStart])
  @@index([branchId, year, month])
  @@index([periodType, periodStart])
  @@index([status, periodStart])
  @@index([currency])
}

model BranchAudit {
  id             String   @id @default(cuid())
  branchId       String
  title          String
  status         String   @default("DRAFT")
  auditDate      DateTime @default(now())
  score          Float?
  criticalCount  Int      @default(0)
  summary        String?
  createdById    String?
  approvedById   String?
  completedAt    DateTime?
  approvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@index([branchId, auditDate])
  @@index([status, auditDate])
}

model BranchDevelopmentPlan {
  id          String   @id @default(cuid())
  branchId    String
  title       String
  status      String   @default("OPEN")
  priority    String   @default("NORMAL")
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@index([branchId, status])
  @@index([dueDate, status])
}

model OperationCalendarItem {
  id          String   @id @default(cuid())
  branchId    String
  title       String
  description String?
  eventType   String
  startAt     DateTime
  endAt       DateTime?
  status      String   @default("PLANNED")
  taskId      String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@index([branchId, startAt])
  @@index([status, startAt])
}

model BranchTimelineEvent {
  id          String   @id @default(cuid())
  branchId    String
  userId      String?
  action      String
  entityType  String
  entityId    String?
  oldValue    String?
  newValue    String?
  description String
  createdAt   DateTime @default(now())
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([branchId, createdAt])
  @@index([action, createdAt])
}

model BranchOpening {
  id                 String         @id @default(cuid())
  branchId           String
  title              String
  status             String         @default("PLANNING")
  plannedStartDate   DateTime?
  plannedOpeningDate DateTime
  actualOpeningDate  DateTime?
  progressPercentage Int            @default(0)
  projectManager     String?
  generalNotes       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  archivedAt         DateTime?
  branch             Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  stages             OpeningStage[]
  documents          Document[]

  @@index([branchId, archivedAt])
  @@index([status, plannedOpeningDate])
}

model OpeningStage {
  id                 String        @id @default(cuid())
  openingId          String
  stageType          String
  title              String
  description        String?
  status             String        @default("NOT_STARTED")
  assignedTo         String?
  plannedStartDate   DateTime?
  dueDate            DateTime?
  completedAt        DateTime?
  progressPercentage Int           @default(0)
  orderIndex         Int
  delayReason        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  opening            BranchOpening @relation(fields: [openingId], references: [id], onDelete: Restrict)
  tasks              OpeningTask[]

  @@index([openingId, orderIndex])
  @@index([status, dueDate])
}

model OpeningTask {
  id             String       @id @default(cuid())
  openingStageId String
  title          String
  description    String?
  assignedTo     String?
  priority       String       @default("NORMAL")
  status         String       @default("OPEN")
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  stage          OpeningStage @relation(fields: [openingStageId], references: [id], onDelete: Restrict)

  @@index([openingStageId, dueDate])
  @@index([status, dueDate])
}

model CandidateTask {
  id             String             @id @default(cuid())
  candidateId    String
  title          String
  description    String?
  dueDate        DateTime
  priority       String             @default("Normal")
  status         String             @default("Açık")
  assignedUserId String?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  candidate      FranchiseCandidate @relation(fields: [candidateId], references: [id], onDelete: Restrict)

  @@index([candidateId, dueDate])
  @@index([status, dueDate])
  @@index([assignedUserId])
}

model CandidateInteraction {
  id              String             @id @default(cuid())
  candidateId     String
  interactionType String
  title           String
  description     String
  interactionDate DateTime
  nextAction      String?
  reminderAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  candidate       FranchiseCandidate @relation(fields: [candidateId], references: [id], onDelete: Restrict)

  @@index([candidateId, interactionDate])
}

model Lead {
  id                   String         @id @default(cuid())
  fullName             String
  phone                String
  email                String?
  city                 String
  source               String
  requestedConcept     String
  status               String         @default("NEW")
  processStatus        String         @default("NEW")
  leadCategory         String?
  nextFollowUpAt       DateTime?
  assignedUserId       String?
  lastContactAt        DateTime?
  investmentBudget     String?
  interestedLocation   String?
  leadDate             DateTime       @default(now())
  convertedCandidateId String?
  normalizedPhone      String?
  normalizedEmail      String?
  externalLeadId       String?        @unique
  metaFormId           String?
  metaPageId           String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  activities           LeadActivity[]
  appointments         LeadAppointment[]
  tasks                LeadTask[]

  @@index([status, leadDate])
  @@index([processStatus, leadDate])
  @@index([leadCategory])
  @@index([nextFollowUpAt])
  @@index([assignedUserId])
  @@index([source])
  @@index([convertedCandidateId])
  @@index([normalizedPhone])
  @@index([normalizedEmail])
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  type        String
  description String
  createdAt   DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Restrict)

  @@index([leadId, createdAt])
}

model LeadAppointment {
  id              String   @id @default(cuid())
  leadId          String
  appointmentDate DateTime
  appointmentTime String
  appointmentType String
  assignedUserId  String?
  createdByUserId String?
  createdById     String?
  startDateTime   DateTime?
  endDateTime     DateTime?
  type            String?
  status          String   @default("SCHEDULED")
  title           String
  description     String?
  location        String?
  meetingLink     String?
  notes           String?
  outcome         String?
  result          String?
  cancellationReason String?
  rescheduleReason   String?
  previousAppointmentDate DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Restrict)

  @@index([leadId, appointmentDate])
  @@index([startDateTime])
  @@index([status, appointmentDate])
  @@index([assignedUserId])
}

model LeadTask {
  id             String   @id @default(cuid())
  leadId         String
  title          String
  description    String?
  dueDate        DateTime
  priority       String   @default("Normal")
  status         String   @default("Açık")
  assignedUserId String?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Restrict)

  @@index([leadId, dueDate])
  @@index([status, dueDate])
  @@index([assignedUserId])
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String?   @unique
  description String?
  parentCategoryId String?
  sortOrder   Int       @default(0)
  orderIndex  Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  parent      ProductCategory?  @relation("ProductCategoryTree", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  children    ProductCategory[] @relation("ProductCategoryTree")
  products    Product[]

  @@index([parentCategoryId])
  @@index([code])
}

model Product {
  id                String               @id @default(cuid())
  name              String
  sku               String               @unique
  barcode           String?              @unique
  shortName         String?
  categoryId        String
  brand             String?
  unit              String               @default("Adet")
  packageQuantity   Float?
  packageUnit       String?
  baseUnit          String?
  conversionFactor  Float                @default(1)
  minimumOrderQuantity Float             @default(1)
  orderIncrement    Float                @default(1)
  vatRate           Float                @default(20)
  purchasePrice     Float                @default(0)
  salePrice         Float
  currency          String               @default("TRY")
  minimumStockLevel Float                @default(0)
  trackInventory    Boolean              @default(true)
  trackLot          Boolean              @default(false)
  trackExpiration   Boolean              @default(false)
  shelfLifeDays     Int?
  storageCondition  String?
  isOrderable       Boolean              @default(true)
  centralSupplyPolicy String             @default("PREFERRED_CENTRAL")
  isActive          Boolean              @default(true)
  parasutProductId  String?
  ticimaxProductId  String?
  createdById       String?
  description       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  archivedAt        DateTime?
  category          ProductCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  stocks            WarehouseStock[]
  movements         StockMovement[]
  orderItems        FranchiseOrderItem[]
  externalMappings  ExternalProductMapping[]
  mappingQueueSuggestions ProductMappingQueue[] @relation("SuggestedProduct")
  mappingQueueMatches ProductMappingQueue[] @relation("MatchedProduct")
  lots              InventoryLot[]
  goodsReceiptItems GoodsReceiptItem[]
  pickingItems      PickingListItem[]
  shipmentItems     ShipmentItem[]
  returnItems       ReturnItem[]
  inventoryLosses   InventoryLoss[]
  stockCountItems   StockCountItem[]
  supplyAlerts      SupplyComplianceAlert[]

  @@index([categoryId, isActive])
  @@index([name])
  @@index([centralSupplyPolicy])
  @@index([isOrderable, isActive])
}

model Warehouse {
  id                String           @id @default(cuid())
  name              String           @unique
  code              String?          @unique
  type              String           @default("CENTRAL")
  status            String           @default("ACTIVE")
  country           String           @default("Türkiye")
  city              String
  district          String?
  address           String?
  latitude          Float?
  longitude         Float?
  responsiblePerson String?
  phone             String?
  email             String?
  managerUserId     String?
  createdById       String?
  notes             String?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  archivedAt        DateTime?
  stocks            WarehouseStock[]
  movements         StockMovement[]
  orders            FranchiseOrder[]
  shipments         Shipment[]
  lots              InventoryLot[]
  goodsReceipts     GoodsReceipt[]
  pickingLists      PickingList[]
  returns           ReturnRequest[]
  inventoryLosses   InventoryLoss[]
  stockCounts       StockCount[]
  supplyAlerts      SupplyComplianceAlert[]

  @@index([code])
  @@index([type, status])
  @@index([city])
}

model WarehouseStock {
  id                String    @id @default(cuid())
  warehouseId       String
  productId         String
  quantity          Float     @default(0)
  reservedQuantity  Float     @default(0)
  availableQuantity Float     @default(0)
  minimumStockLevel Float     @default(0)
  reorderPoint      Float?
  maximumStockLevel Float?
  averageCost       Float?
  lastPurchasePrice Float?
  lastMovementAt    DateTime?
  lastCountedAt     DateTime?
  version           Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  product           Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([warehouseId, productId])
  @@index([productId])
  @@index([warehouseId, updatedAt])
}

model StockMovement {
  id             String    @id @default(cuid())
  warehouseId    String
  productId      String
  lotId          String?
  movementType   String
  direction      String    @default("IN")
  quantity       Float
  unitCost       Float?
  totalCost      Float?
  beforeQuantity Float
  afterQuantity  Float
  previousQuantity Float?
  newQuantity    Float?
  referenceType  String?
  referenceId    String?
  reasonCode     String?
  description    String?
  notes          String?
  documentId     String?
  performedById  String?
  approvedById   String?
  occurredAt     DateTime  @default(now())
  createdBy      String?
  createdAt      DateTime  @default(now())
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  product        Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  lot            InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([warehouseId, createdAt])
  @@index([productId, createdAt])
  @@index([lotId])
  @@index([movementType, occurredAt])
  @@index([referenceType, referenceId])
}

model FranchiseOrder {
  id                    String               @id @default(cuid())
  orderNumber           String               @unique
  franchiseeId          String
  branchId              String?
  customerName          String?
  source                String               @default("MANUAL_OTHER")
  orderType             String               @default("FRANCHISE_SALE")
  warehouseId           String
  externalOrderId       String?
  ticimaxOrderNumber    String?
  status                String               @default("SUBMITTED")
  invoiceStatus         String               @default("NOT_CREATED")
  parasutInvoiceId      String?
  parasutInvoiceNumber  String?
  invoicedAt            DateTime?
  invoiceTotal          Decimal?             @db.Decimal(18, 2)
  invoiceCurrency       String?
  financialStatus       String               @default("INVOICE_PENDING")
  subtotal              Float
  vatTotal              Float
  grandTotal            Float
  currency              String               @default("TRY")
  requestedDeliveryDate DateTime?
  approvedAt            DateTime?
  reservedAt            DateTime?
  pickingStartedAt      DateTime?
  packedAt              DateTime?
  readyToShipAt         DateTime?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  rejectedAt            DateTime?
  cancelledAt           DateTime?
  notes                 String?
  createdBy             String?
  approvedBy            String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  franchisee            Franchisee           @relation(fields: [franchiseeId], references: [id], onDelete: Restrict)
  branch                Branch?              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  warehouse             Warehouse            @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  items                 FranchiseOrderItem[]
  activities            OrderActivity[]
  shipment              Shipment?
  pickingLists          PickingList[]
  returnRequests        ReturnRequest[]
  deliveryIssues        DeliveryIssue[]
  supplyAlerts          SupplyComplianceAlert[]

  @@unique([source, externalOrderId])
  @@unique([ticimaxOrderNumber])
  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([orderType, createdAt])
  @@index([financialStatus, createdAt])
  @@index([parasutInvoiceId])
  @@index([franchiseeId, createdAt])
  @@index([branchId, createdAt])
  @@index([warehouseId, status])
}

model FranchiseOrderItem {
  id               String         @id @default(cuid())
  orderId          String
  productId        String
  productName      String
  sku              String
  unit             String
  quantity         Float
  approvedQuantity Float?
  reservedQuantity Float          @default(0)
  pickedQuantity   Float          @default(0)
  packedQuantity   Float          @default(0)
  shippedQuantity  Float          @default(0)
  deliveredQuantity Float         @default(0)
  returnedQuantity Float          @default(0)
  preparedQuantity Float          @default(0)
  missingQuantity  Float          @default(0)
  unitPrice        Float
  vatRate          Float
  lineSubtotal     Float
  lineVat          Float
  lineTotal        Float
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  order            FranchiseOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  product          Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  pickingItems     PickingListItem[]
  shipmentItems    ShipmentItem[]
  returnItems      ReturnItem[]

  @@index([orderId])
  @@index([productId])
}

model OrderActivity {
  id          String         @id @default(cuid())
  orderId     String
  type        String
  description String
  createdBy   String?
  createdAt   DateTime       @default(now())
  order       FranchiseOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
}

model Shipment {
  id             String         @id @default(cuid())
  shipmentNumber String         @unique
  orderId        String         @unique
  warehouseId    String
  status         String         @default("PREPARING")
  shipmentType   String         @default("CARGO")
  carrierName    String?
  trackingNumber String?
  vehiclePlate   String?
  driverName     String?
  driverPhone    String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  deliveredById  String?
  receivedByName String?
  deliveryProblemStatus String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  order          FranchiseOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  items          ShipmentItem[]
  deliveryIssues DeliveryIssue[]

  @@index([warehouseId, status])
  @@index([status, shippedAt])
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique
  taxNumber   String?
  taxOffice   String?
  phone       String?
  email       String?
  address     String?
  status      String   @default("ACTIVE")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  archivedAt  DateTime?
  productMappings ExternalProductMapping[]
  goodsReceipts GoodsReceipt[]
  lots        InventoryLot[]

  @@index([name])
  @@index([status])
}

model ExternalProductMapping {
  id                String   @id @default(cuid())
  productId         String
  sourceSystem      String
  externalProductId String
  externalSku       String?
  externalBarcode   String?
  externalName      String
  supplierId        String?
  conversionFactor  Float    @default(1)
  externalUnit      String?
  isActive          Boolean  @default(true)
  lastMatchedAt     DateTime?
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  product           Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplier          Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@unique([sourceSystem, externalProductId, isActive])
  @@index([productId, sourceSystem])
  @@index([externalSku])
  @@index([externalBarcode])
}

model ProductMappingQueue {
  id                String   @id @default(cuid())
  sourceSystem      String
  externalProductId String?
  externalName      String
  externalSku       String?
  externalBarcode   String?
  externalUnit      String?
  sourceDocumentId  String?
  sourceOrderId     String?
  status            String   @default("PENDING")
  suggestedProductId String?
  matchedProductId  String?
  reviewedById      String?
  reviewedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  suggestedProduct  Product? @relation("SuggestedProduct", fields: [suggestedProductId], references: [id], onDelete: SetNull)
  matchedProduct    Product? @relation("MatchedProduct", fields: [matchedProductId], references: [id], onDelete: SetNull)

  @@index([sourceSystem, status])
  @@index([externalProductId])
  @@index([suggestedProductId])
  @@index([matchedProductId])
}

model ExternalBranchMapping {
  id                 String   @id @default(cuid())
  branchId           String
  sourceSystem       String
  externalCustomerId String?
  externalStoreId    String?
  externalCode       String?
  externalName       String
  status             String   @default("ACTIVE")
  lastSyncedAt       DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  branch             Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([sourceSystem, externalCustomerId])
  @@index([branchId, sourceSystem])
  @@index([externalCode])
}

model InventoryLot {
  id                 String   @id @default(cuid())
  warehouseId        String
  productId          String
  lotNumber          String
  productionDate     DateTime?
  expirationDate     DateTime?
  quantityOnHand     Float    @default(0)
  quantityReserved   Float    @default(0)
  supplierId         String?
  goodsReceiptItemId String?
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  warehouse          Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  product            Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplier           Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  goodsReceiptItem   GoodsReceiptItem? @relation(fields: [goodsReceiptItemId], references: [id], onDelete: SetNull)
  movements          StockMovement[]
  pickingItems       PickingListItem[]
  shipmentItems      ShipmentItem[]

  @@unique([warehouseId, productId, lotNumber])
  @@index([expirationDate, status])
  @@index([productId, status])
}

model GoodsReceipt {
  id                 String   @id @default(cuid())
  warehouseId        String
  supplierId         String?
  sourceSystem       String   @default("MANUAL")
  externalDocumentId String?
  invoiceNumber      String?
  invoiceDate        DateTime?
  deliveryDate       DateTime?
  status             String   @default("PENDING_RECEIPT")
  totalExpectedItems Float    @default(0)
  totalReceivedItems Float    @default(0)
  discrepancyStatus  String   @default("NONE")
  receivedById       String?
  approvedById       String?
  completedAt        DateTime?
  approvedAt         DateTime?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  warehouse          Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  supplier           Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items              GoodsReceiptItem[]

  @@index([warehouseId, status])
  @@index([sourceSystem, externalDocumentId])
  @@index([invoiceNumber])
}

model GoodsReceiptItem {
  id                String   @id @default(cuid())
  goodsReceiptId    String
  productId         String?
  externalProductId String?
  expectedQuantity  Float    @default(0)
  receivedQuantity  Float    @default(0)
  acceptedQuantity  Float    @default(0)
  damagedQuantity   Float    @default(0)
  missingQuantity   Float    @default(0)
  excessQuantity    Float    @default(0)
  unit              String
  unitCost          Float?
  lotNumber         String?
  productionDate    DateTime?
  expirationDate    DateTime?
  discrepancyReason String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  goodsReceipt      GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Restrict)
  product           Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  lots              InventoryLot[]

  @@index([goodsReceiptId])
  @@index([productId])
  @@index([externalProductId])
}

model PickingList {
  id            String   @id @default(cuid())
  orderId       String
  warehouseId   String
  status        String   @default("OPEN")
  assignedUserId String?
  startedAt     DateTime?
