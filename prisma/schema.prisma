  lot             InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([pickingListId])
  @@index([orderItemId])
  @@index([lotId])
}

model ShipmentItem {
  id              String   @id @default(cuid())
  shipmentId      String
  orderItemId     String
