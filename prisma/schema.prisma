  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  returnRequest ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Restrict)
  orderItem   FranchiseOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([returnId])
  @@index([orderItemId])
}

model InventoryLoss {
  id          String   @id @default(cuid())
